{
	"info": {
		"_postman_id": "docvanta-complete-collection-2024",
		"name": "DOCVANTA Backend - Complete API Collection",
		"description": "Complete API collection for DOCVANTA Medical Clinic Management System\n\n**Base URL:** http://localhost:8081\n\n**Authentication:** JWT Bearer Token (obtained from login)\n\n**Usage Instructions:**\n1. First, run the 'Register' request to create a user\n2. Then run 'Login' to get the JWT token\n3. The token will be automatically saved to the collection variable\n4. All subsequent requests will use this token automatically",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"auth": {
		"type": "bearer",
		"bearer": [
			{
				"key": "token",
				"value": "{{jwt_token}}",
				"type": "string"
			}
		]
	},
	"variable": [
		{
			"key": "base_url",
			"value": "http://localhost:8081",
			"type": "string"
		},
		{
			"key": "jwt_token",
			"value": "",
			"type": "string"
		},
		{
			"key": "user_id",
			"value": "",
			"type": "string"
		}
	],
	"item": [
		{
			"name": "Authentication",
			"item": [
				{
					"name": "Register Patient",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"if (pm.response.code === 200) {",
									"    var jsonData = pm.response.json();",
									"    if (jsonData.token) {",
									"        pm.collectionVariables.set(\"jwt_token\", jsonData.token);",
									"        console.log(\"Token saved:\", jsonData.token);",
									"    }",
									"    if (jsonData.userId) {",
									"        pm.collectionVariables.set(\"user_id\", jsonData.userId);",
									"    }",
									"}"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"auth": {
							"type": "noauth"
						},
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"username\": \"patient1\",\n  \"password\": \"password123\",\n  \"firstName\": \"John\",\n  \"lastName\": \"Doe\",\n  \"email\": \"john.doe@example.com\",\n  \"phone\": \"+1234567890\",\n  \"userType\": \"PATIENT\"\n}"
						},
						"url": {
							"raw": "{{base_url}}/api/auth/register",
							"host": [
								"{{base_url}}"
							],
							"path": [
								"api",
								"auth",
								"register"
							]
						},
						"description": "Register a new user (PATIENT, DOCTOR, or STAFF)"
					},
					"response": []
				},
