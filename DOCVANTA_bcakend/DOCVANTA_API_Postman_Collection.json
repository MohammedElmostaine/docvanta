									"if (pm.response.code === 200) {",
									"    var jsonData = pm.response.json();",
									"    pm.collectionVariables.set(\"jwtToken\", jsonData.token);",
									"    console.log(\"Doctor Token saved: \" + jsonData.token);",
									"}"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"username\": \"doctor1\",\n    \"password\": \"password123\"\n}"
						},
						"url": {
							"raw": "{{baseUrl}}/api/auth/login",
							"host": ["{{baseUrl}}"],
							"path": ["api", "auth", "login"]
						},
						"description": "Authenticate a doctor and get JWT token"
					},
					"response": []
				}
			],
			"description": "Authentication endpoints for registering and logging in users"
		},
		{
			"name": "Protected Endpoints Test",
			"item": [
				{
					"name": "Test Protected Endpoint (No Token)",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{baseUrl}}/api/test",
							"host": ["{{baseUrl}}"],
							"path": ["api", "test"]
						},
						"description": "Test accessing a protected endpoint without a token. Should return 401 Unauthorized."
					},
					"response": []
				},
				{
					"name": "Test Protected Endpoint (With Token)",
					"request": {
						"auth": {
							"type": "bearer",
							"bearer": [
								{
									"key": "token",
									"value": "{{jwtToken}}",
									"type": "string"
								}
							]
						},
						"method": "GET",
						"header": [
							{
								"key": "Authorization",
								"value": "Bearer {{jwtToken}}",
								"type": "text"
							}
						],
						"url": {
							"raw": "{{baseUrl}}/api/test",
							"host": ["{{baseUrl}}"],
							"path": ["api", "test"]
						},
						"description": "Test accessing a protected endpoint with a valid JWT token."
					},
					"response": []
				}
			],
			"description": "Test protected endpoints with and without JWT token"
		}
	],
	"auth": {
		"type": "bearer",
		"bearer": [
			{
				"key": "token",
				"value": "{{jwtToken}}",
				"type": "string"
			}
		]
	},
	"event": [
		{
			"listen": "prerequest",
			"script": {
				"type": "text/javascript",
				"exec": [
					""
				]
			}
		},
		{
			"listen": "test",
			"script": {
				"type": "text/javascript",
				"exec": [
					""
				]
			}
		}
	]
